{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --prefix frontend --legacy-peer-deps",
  "functions": {
    "api/main.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/main.py"
    },
    {
      "source": "/(backend|database|frontend/src|frontend/public)/(.*)",
      "destination": "/404"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
