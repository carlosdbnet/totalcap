{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install --prefix frontend --legacy-peer-deps",
  "outputDirectory": "production_build",
  "functions": {
    "api/main.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
